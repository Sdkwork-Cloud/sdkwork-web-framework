  "contracts": {
    "requestContextFramework": {
      "contextType": "WebRequestContext",
      "legacyAlias": "AppRequestContext",
      "mandatoryPipelineStages": 18,
      "standardDocument": "specs/WEB_FRAMEWORK_STANDARD.md",
      "capabilityMatrix": "specs/web-framework-capability.matrix.json"
    },
    "apiSurfaces": ["open-api", "app-api", "backend-api"],
    "extensionTraits": [
      "WebRequestContextResolver",
      "AuthorizationPolicy",
      "TenantIsolationPolicy",
      "DomainContextInjector",
      "ApiKeyLookupService",
      "OAuthTokenLookupService",
      "OpenApiCredentialSchemeDetector",
      "TenantSigningKeyLookup",
      "JwtSessionRevocationChecker",
      "RateLimitStore",
      "IdempotencyStore",
      "ConcurrentAdmissionStore",
      "AuditEmitter",
      "SecurityEventEmitter",
      "ReadinessCheck",
      "WebFrameworkLifecycle",
      "DynamicCorsPolicySource",
      "DynamicRateLimitPolicySource",
      "DynamicTenantRuntimeProfileSource"
    ],
    "dependencyRule": "business-repos-depend-on-framework; framework-must-not-depend-on-business",
    "runtimeEntrypoints": [
      "crates/sdkwork-web-admin-server/src/main.rs",
      "scripts/verify.ps1",
      "scripts/verify.sh"
    ]
  },
  "verification": {
    "commands": [
      "cargo test --workspace",
      "cargo clippy --workspace -- -D warnings",
      "cargo test -p sdkwork-web-admin-server",
      "cargo test -p sdkwork-web-architecture-tests",
      "cargo test --release -p sdkwork-web-architecture-tests --test pipeline_benchmark",
      "cargo test -p sdkwork-web-bootstrap --test integration",
      "cargo test -p sdkwork-router-web-framework-backend-api --test openapi_authority",
      "cargo test -p sdkwork-router-web-framework-backend-api --test routes_contract",
      "cargo test -p sdkwork-web-bootstrap --features admin-api --test admin_api_readiness",
      "node tests/contract/database-framework.contract.test.mjs",
      "node scripts/generate-pc-admin-operations.mjs --check",
      "node tests/contract/pc-admin-operations.contract.test.mjs",
      "node tests/contract/pc-admin-build.smoke.test.mjs",
      "cd apps/sdkwork-web-framework-pc && npm run test:e2e",
      "node tests/contract/pc-admin-e2e-build.contract.test.mjs",
      "node tests/contract/production-rollout.contract.test.mjs",
      "node tests/contract/release-evidence.contract.test.mjs",
      "node tests/contract/adoption-evidence.contract.test.mjs",
      "node scripts/collect-release-evidence.mjs",
      "cd apps/sdkwork-web-framework-pc && npm run test:e2e:integration",
      "cd apps/sdkwork-web-framework-pc && npm run verify"
    ]
  },
  "metadata": {
    "managedBy": "sdkwork-web-framework design rev.3",
