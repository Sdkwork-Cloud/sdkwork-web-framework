              "$ref": "#/components/schemas/FieldError"
            },
            "type": "array"
          },
          "instance": {
            "type": "string"
          },
          "status": {
            "maximum": 599,
            "minimum": 100,
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "traceId": {
            "description": "Server-owned request correlation id.",
            "format": "uuid",
            "type": "string"
          },
          "type": {
            "format": "uri-reference",
            "type": "string"
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "code",
          "traceId"
        ],
        "type": "object"
      },
      "SdkWorkApiResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "default": 0,
            "enum": [
              0
            ],
            "format": "int32",
            "maximum": 0,
            "minimum": 0,
            "type": "integer"
          },
          "data": {
            "description": "Operation-specific payload typed per response schema."
          },
          "traceId": {
            "description": "Server-owned request correlation id.",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "code",
          "data",
          "traceId"
        ],
        "type": "object"
      },
      "SdkWorkCommandData": {
        "additionalProperties": false,
        "properties": {
          "accepted": {
            "const": true,
            "type": "boolean"
          },
          "resourceId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "accepted"
        ],
        "type": "object"
      },
      "SdkWorkCommandResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "properties": {
              "data": {
                "$ref": "#/components/schemas/SdkWorkCommandData"
              }
            },
            "required": [
              "data"
            ],
            "type": "object"
          }
        ]
