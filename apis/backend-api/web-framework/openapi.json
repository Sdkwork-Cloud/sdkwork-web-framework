            "minimum": 1,
            "type": "integer"
          },
          "pageSize": {
            "maximum": 200,
            "minimum": 1,
            "type": "integer"
          },
          "totalItems": {
            "pattern": "^[0-9]+$",
            "type": "string"
          },
