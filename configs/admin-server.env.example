# sdkwork-web-admin-server — non-secret environment template
# Copy to your secret manager / container env; never commit real secrets.
# See docs/21-operations-runbook.md and deployments/README.md

# Deployment profile (prod enables production_assembly validation at build())
SDKWORK_WEB_FRAMEWORK_ENV=prod

# HTTP bind address
SDKWORK_WEB_FRAMEWORK_ADMIN_BIND=0.0.0.0:3920

# SQLx store for admin control-plane tables (web_*)
SDKWORK_WEB_FRAMEWORK_STORE_URL=sqlite:./data/web-framework.db?mode=rwc

# SQLx connection pool size (default 8)
SDKWORK_WEB_FRAMEWORK_STORE_POOL_SIZE=8

# Required: HS256 bootstrap signing secret for control-plane JWT
SDKWORK_WEB_FRAMEWORK_JWT_HS256_SECRET=change-me-use-secret-manager

# Optional bootstrap tenant/key identifiers (defaults: bootstrap / bootstrap)
SDKWORK_WEB_FRAMEWORK_JWT_BOOTSTRAP_TENANT_ID=bootstrap
SDKWORK_WEB_FRAMEWORK_JWT_BOOTSTRAP_KEY_ID=bootstrap

# Production SaaS: Redis HA for rate limit, idempotency, concurrent admission
SDKWORK_WEB_FRAMEWORK_REDIS_URL=redis://127.0.0.1:6379

# Optional: run live Redis integration tests during verify (rate limit + idempotency replay)
# SDKWORK_REDIS_TEST_URL=redis://127.0.0.1:6379

# OpenTelemetry (admin-server binary enables bootstrap `otel` feature)
OTEL_SERVICE_NAME=sdkwork-web-admin-server
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Structured logging (redacts credential headers in bootstrap tracing)
RUST_LOG=info,sdkwork_web=debug
