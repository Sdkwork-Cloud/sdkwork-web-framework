# SDKWork Web Framework PC console — backend-api dual-token bootstrap (dev/local only).
# Copy to .env.development.local and fill with IAM/bootstrap issued JWTs.

VITE_SDKWORK_WEB_FRAMEWORK_BACKEND_API_BASE_URL=http://127.0.0.1:3920
# Dev/E2E-only bootstrap Access-Token JWT (tenant isolation). Vite bakes VITE_*
# vars into the client bundle, so NEVER put a production secret here. Production
# deployments inject credentials at runtime via window.__SDKWORK_ADMIN_CREDENTIALS__
# (see src/sdk/auth/token-provider.ts).
VITE_SDKWORK_ACCESS_TOKEN=
